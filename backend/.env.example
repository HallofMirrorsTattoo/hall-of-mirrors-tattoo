# JWT
JWT_SECRET="your_jwt_secret_min_32_characters"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_min_32_characters"

# API
PORT=5000
NODE_ENV="development"
CORS_ORIGIN=""

# Stripe (test keys)
STRIPE_PUBLIC_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PayPal (test credentials)
PAYPAL_CLIENT_ID="your_client_id"
PAYPAL_SECRET="your_secret"

# SendGrid
SENDGRID_API_KEY="your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="studio@hallofmirrorstattoo.com"
STUDIO_EMAIL="studio@hallofmirrorstattoo.com"

# AWS S3
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_S3_BUCKET="hallofmirrors-tattoo-images"
AWS_REGION="eu-west-1"

# Sentry (optional)
SENTRY_DSN=""

# Database
DATABASE_URL="your_database_url"
